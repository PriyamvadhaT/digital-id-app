# Digital ID Backend - Deployment Template
# Copy this to .env and fill in real values

PORT=3000
MONGO_URI=mongodb+srv://<USER>:<PASS>@<CLUSTER>.mongodb.net/digital_id
JWT_SECRET=generate-a-long-random-string-here

# 🛡️ SECURITY TIPS:
# 1. Use a strong JWT_SECRET (at least 64 characters)
# 2. Use a managed MongoDB service (like MongoDB Atlas) for production
# 3. Ensure the PORT matches your server configuration
